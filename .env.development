# Fill these in after creating the dev Firebase project at console.firebase.google.com
REACT_APP_FIREBASE_API_KEY=REPLACE_WITH_DEV_API_KEY
REACT_APP_FIREBASE_AUTH_DOMAIN=REPLACE_WITH_DEV_PROJECT_ID.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=REPLACE_WITH_DEV_PROJECT_ID
REACT_APP_FIREBASE_STORAGE_BUCKET=REPLACE_WITH_DEV_PROJECT_ID.firebasestorage.app
